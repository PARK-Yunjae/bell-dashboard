__pycache__/
.venv/
*.pyc

# Streamlit secrets (절대 push 금지: API key, Discord webhook URL, 계좌정보 등)
.streamlit/secrets.toml
.env
.env.*

# 백업 / 임시
*.bak
*.bak.*
*.tmp
*.swp
*~

# 로컬 캡처 / 스크린샷
_capture/
screenshots/

# 큰 raw 데이터 (절대 GitHub 금지)
data/market/
data/dart/
data/closingbell/backtests/
data/closingbell/research_index/
data/closingbell/shared/
data/closingbell/scheduled/
data/closingbell/quality/
data/closingbell/simulations/

# 사용자 개인 메모 (push 금지)
data/closingbell/user_notes/
memo/

# GitHub-safe online snapshot exported by bell-data.
!data/
!data/closingbell/
!data/closingbell/online_v2/
!data/closingbell/online_v2/**

# 운영 산출물 / 발송 로그 (절대 push 금지)
*sent_log*
*paper_watch_sent_log*

# Streamlit 로컬 실행 로그
streamlit_*.log
streamlit_*.out.log
streamlit_*.err.log

# bellguard_pricecap_1y / bellguard_1y / v2_record_1y / v2_hybrid_1y
# → online_v2/latest 화이트리스트 안에 있어 자동 포함됨.
# 다만 bellguard_pricecap_1y 는 d0_strict_1y 로 이름이 바뀌어 더는 사용 안 함.
# 옛 폴더가 남아 있어도 dataset resolver 우선순위에서 d0_strict_1y 가 이김.
